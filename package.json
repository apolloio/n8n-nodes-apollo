{
  "name": "@apolloio/n8n-nodes-apollo",
  "version": "0.2.8",
  "description": "Official n8n community node for Apollo.io — enrich people and organizations from Apollo's 275M+ contact database.",
  "keywords": [
    "n8n-community-node-package",
    "apollo",
    "apollo-io",
    "enrichment",
    "sales",
    "leads"
  ],
  "license": "MIT",
  "homepage": "https://github.com/apolloio/n8n-nodes-apollo",
  "repository": {
    "type": "git",
    "url": "https://github.com/apolloio/n8n-nodes-apollo.git"
  },
  "author": {
    "name": "Apollo.io",
    "email": "support@apollo.io"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "pnpm build",
    "test": "jest"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ApolloApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Apollo/Apollo.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "gulp": "^4.0.0",
    "jest": "^30.4.2",
    "n8n-workflow": "^2.16.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
